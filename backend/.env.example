# Copy to .env and fill in your values. Never commit .env.
# ── LLM (document extraction) ─────────────────────────────────────────────────
# Provider preference: Anthropic when set → Gemini → offline content-lift (the demo
# profiles carry inline content, so they adjudicate with no key; real uploads need one).
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=your_gemini_api_key_here

# ── Policy (optional override) ────────────────────────────────────────────────
# POLICY_PATH=/path/to/custom_policy_terms.json

# ── Database (Part 8) ─────────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Redis / Upstash (Part 8) ──────────────────────────────────────────────────
# REDIS_URL=rediss://default:password@host:port

# ── CORS (Part 8) ─────────────────────────────────────────────────────────────
# FRONTEND_URL=http://localhost:3000

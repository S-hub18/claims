# Frontend environment — copy to .env.local.
# Every NEXT_PUBLIC_* var is bundled into the browser, so only ever put
# publishable values here (never a secret/service key).

# Supabase — the demo roster + documents are read from here.
# This is the PUBLISHABLE anon key: safe to expose in the browser; the data
# behind it is protected by row-level security.
NEXT_PUBLIC_SUPABASE_URL=https://qxcbdzkjsrnvbzlojvxp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_wPQ15PzST4DBsJU8zxAhEw_Jb_mGxP5

# FastAPI adjudication backend. Defaults to http://localhost:8000 when unset.
NEXT_PUBLIC_API_URL=http://localhost:8000
